generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum DoctorStatus {
  DUTY
  LEAVE
}

enum Specialization {
  CONSULTANT_SURGEON
  DERMATOLOGIST
  GENERAL_PHYSICIAN
  PEDIATRICIAN
}

enum AppointmentStatus {
  WAITING
  NOW_SERVING
  COMPLETED
  CANCELLED
}

model Doctor {
  id             String         @id @default(uuid())
  name           String
  email          String         @unique
  phone          String
  specialization Specialization
  availableTime  String
  status         DoctorStatus   @default(DUTY)
  appointments   Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id              String            @id @default(uuid())
  patientName     String
  phone           String
  doctorId        String
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  specialization  Specialization
  tokenNumber     Int
  status          AppointmentStatus @default(WAITING)
  appointmentDate DateTime
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([doctorId, appointmentDate])
}
